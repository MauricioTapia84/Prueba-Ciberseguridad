FROM jenkins/jenkins:lts
USER root
RUN apt-get update && \
    apt-get install -y python3 python3-venv python3-pip docker.io jq curl procps && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Create an auxiliary group matching the host docker GID so the Jenkins user can access the mounted socket
ARG DOCKER_GID=985
RUN groupadd -g ${DOCKER_GID} host_docker || true \
    && usermod -aG host_docker jenkins || true

USER jenkins
ENV DOCKER_HOST=unix:///var/run/docker.sock
